<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="employee_directory" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <parameter name="P_DEPARTMENT_ID" class="java.lang.Integer"/>
    <parameter name="P_TENANT_SCHEMA" class="java.lang.String">
        <defaultValueExpression><![CDATA["PUBLIC"]]></defaultValueExpression>
    </parameter>
    <queryString language="SQL"><![CDATA[
        SELECT e.employee_id, e.first_name || ' ' || e.last_name AS full_name,
               e.job_title, d.department_name, e.email, e.phone_number
        FROM employees e LEFT JOIN departments d ON e.department_id = d.department_id
        WHERE (e.department_id = $P{P_DEPARTMENT_ID} OR $P{P_DEPARTMENT_ID} IS NULL)
        ORDER BY d.department_name, e.last_name
    ]]></queryString>
    <field name="EMPLOYEE_ID" class="java.lang.Integer"/>
    <field name="FULL_NAME" class="java.lang.String"/>
    <field name="JOB_TITLE" class="java.lang.String"/>
    <field name="DEPARTMENT_NAME" class="java.lang.String"/>
    <field name="EMAIL" class="java.lang.String"/>
    <field name="PHONE_NUMBER" class="java.lang.String"/>
    <variable name="ROW_COUNT" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{EMPLOYEE_ID}]]></variableExpression>
    </variable>
    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center"><font size="18" isBold="true"/></textElement>
                <text><![CDATA[Employee Directory]]></text>
            </staticText>
        </band>
    </title>
    <columnHeader>
        <band height="22">
            <staticText><reportElement x="0" y="0" width="50" height="20" backcolor="#2C5F8A" mode="Opaque"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" color="#FFFFFF"/></textElement><text><![CDATA[ ID]]></text></staticText>
            <staticText><reportElement x="50" y="0" width="120" height="20" backcolor="#2C5F8A" mode="Opaque"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" color="#FFFFFF"/></textElement><text><![CDATA[ Name]]></text></staticText>
            <staticText><reportElement x="170" y="0" width="100" height="20" backcolor="#2C5F8A" mode="Opaque"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" color="#FFFFFF"/></textElement><text><![CDATA[ Title]]></text></staticText>
            <staticText><reportElement x="270" y="0" width="90" height="20" backcolor="#2C5F8A" mode="Opaque"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" color="#FFFFFF"/></textElement><text><![CDATA[ Department]]></text></staticText>
            <staticText><reportElement x="360" y="0" width="110" height="20" backcolor="#2C5F8A" mode="Opaque"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" color="#FFFFFF"/></textElement><text><![CDATA[ Email]]></text></staticText>
            <staticText><reportElement x="470" y="0" width="85" height="20" backcolor="#2C5F8A" mode="Opaque"/><textElement verticalAlignment="Middle"><font size="8" isBold="true" color="#FFFFFF"/></textElement><text><![CDATA[ Phone]]></text></staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="16">
            <textField><reportElement x="0" y="0" width="50" height="14"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{EMPLOYEE_ID}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="50" y="0" width="120" height="14"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{FULL_NAME}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="170" y="0" width="100" height="14"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{JOB_TITLE}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="270" y="0" width="90" height="14"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{DEPARTMENT_NAME}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="360" y="0" width="110" height="14"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{EMAIL}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="470" y="0" width="85" height="14"/><textElement><font size="7"/></textElement><textFieldExpression><![CDATA[$F{PHONE_NUMBER}]]></textFieldExpression></textField>
        </band>
    </detail>
    <summary>
        <band height="25">
            <textField><reportElement x="0" y="5" width="555" height="15"/><textElement><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA["Total Employees: " + $V{ROW_COUNT}]]></textFieldExpression></textField>
        </band>
    </summary>
    <pageFooter>
        <band height="20">
            <textField><reportElement x="400" y="2" width="155" height="15"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression></textField>
        </band>
    </pageFooter>
</jasperReport>
