# ══════════════════════════════════════════════════════════════
# Environment Variables — Oracle APEX + JasperReports Integration
# ══════════════════════════════════════════════════════════════
#
# Instructions:
#   1. Copy this file:  cp .env.example .env
#   2. Replace ALL placeholder values with your actual credentials
#   3. NEVER commit the .env file to version control
# ══════════════════════════════════════════════════════════════

# ── Oracle Database ──────────────────────────────────────────
ORACLE_SYS_PASSWORD=YOUR_SECURE_SYS_PASSWORD
ORACLE_DB_HOST_PORT=1521

# ── ORDS (Oracle REST Data Services) ────────────────────────
ORDS_HOST_PORT=8181
ORDS_PWD=YOUR_SECURE_ORDS_PASSWORD

# ── JasperReports Server ────────────────────────────────────
JASPER_HOST_PORT=8383
JASPERREPORTS_USERNAME=jasperadmin
JASPERREPORTS_PASSWORD=YOUR_SECURE_JASPER_PASSWORD

# ── JasperReports Database (MariaDB) ────────────────────────
JASPERREPORTS_DATABASE_USER=bn_jasperreports
JASPERREPORTS_DATABASE_PASSWORD=YOUR_SECURE_DB_PASSWORD
JASPERREPORTS_DATABASE_NAME=bitnami_jasperreports
MARIADB_ROOT_PASSWORD=YOUR_SECURE_ROOT_PASSWORD

# ── Docker Network ──────────────────────────────────────────
DOCKER_NETWORK=jasper-network
